/**
 * 全局样式 — 基于 Design System "The Digital Ledger Editorial"
 *
 * 色板:
 *   primary:                 #000000
 *   surface:                 #f9f9fb
 *   surface-container-low:   #f3f3f5
 *   surface-container-lowest:#ffffff
 *   surface-container-high:  #e8e8ea
 *   surface-container-highest:#e2e2e4
 *   on-surface:              #1a1c1d
 *   on-surface-variant:      #474747
 *   secondary:               #5e5e63
 *   outline-variant:         #c6c6c6
 *   error:                   #ba1a1a
 *   on-primary:              #e2e2e2
 */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
               'PingFang SC', 'Microsoft Yahei', sans-serif;
  background-color: #f9f9fb;
  color: #1a1c1d;
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* ===== 通用排版 ===== */

.label-sm {
  font-size: 22rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  color: #474747;
}

.headline-lg {
  font-size: 64rpx;
  font-weight: 600;
  line-height: 1.15;
  color: #000000;
  letter-spacing: -1rpx;
}

.display-lg {
  font-size: 112rpx;
  font-weight: 800;
  line-height: 1;
  color: #000000;
  letter-spacing: -3rpx;
}

.title-md {
  font-size: 36rpx;
  font-weight: 500;
  color: #000000;
}

.body-md {
  font-size: 28rpx;
  color: #474747;
}

/* ===== 通用卡片 ===== */

.card {
  background: #ffffff;
  padding: 48rpx;
  border-radius: 48rpx;
  border: 2rpx solid rgba(0,0,0,0.03);
}

.card-low {
  background: #f3f3f5;
  padding: 48rpx;
  border-radius: 48rpx;
}

/* ===== 页面容器 ===== */

.page-container {
  padding: 0 48rpx 240rpx;
}

/* ===== Tab Bar 底部安全距离 ===== */

.bottom-spacer {
  height: 200rpx;
}
