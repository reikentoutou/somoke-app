.onboarding-page {
  padding-top: 80rpx;
}

.headline-section {
  margin-bottom: 64rpx;
}

.headline-section .label-sm {
  display: block;
  margin-bottom: 12rpx;
}

.onboarding-title {
  display: block;
  margin-bottom: 24rpx;
  font-size: 44rpx;
  font-weight: 600;
}

.onboarding-desc {
  display: block;
  line-height: 1.65;
  color: #474747;
}

.action-card {
  display: block;
  margin-bottom: 32rpx;
  text-decoration: none;
  color: inherit;
  box-sizing: border-box;
}

.action-card-hover {
  opacity: 0.92;
}

.action-label {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 12rpx;
}

.action-hint {
  display: block;
  font-size: 26rpx;
  color: #5e5e63;
}
