<view class="page-container ops-ledger-page">
  <view class="ops-hero">
    <view class="ops-hero-card card">
      <text class="label-sm ops-hero-label">当前库存</text>
      <view class="ops-hero-val-row">
        <text class="ops-hero-val">{{storeInfo.current_stock}}</text>
        <text class="ops-hero-unit">件</text>
      </view>
    </view>
    <view class="ops-hero-card card">
      <text class="label-sm ops-hero-label">当前现金</text>
      <view class="ops-hero-val-row">
        <text class="ops-hero-val">{{storeInfo.current_cash}}</text>
        <text class="ops-hero-unit">円</text>
      </view>
    </view>
  </view>

  <view class="ops-actions">
    <view class="ops-action-btn card-low" hover-class="ops-action-hover" bindtap="onTapRestock">
      <view class="ops-action-icon">进</view>
      <text class="ops-action-text">进货</text>
    </view>
    <view class="ops-action-btn card-low" hover-class="ops-action-hover" bindtap="onTapWithdraw">
      <view class="ops-action-icon">取</view>
      <text class="ops-action-text">取现</text>
    </view>
    <view class="ops-action-btn card-low" hover-class="ops-action-hover" bindtap="onTapAdjustStock">
      <view class="ops-action-icon">库</view>
      <text class="ops-action-text">库存校准</text>
    </view>
    <view class="ops-action-btn card-low" hover-class="ops-action-hover" bindtap="onTapAdjustCash">
      <view class="ops-action-icon">现</view>
      <text class="ops-action-text">现金校准</text>
    </view>
  </view>

  <view class="section-head ops-section-head">
    <text class="title-md section-title">流水</text>
    <text class="body-md ops-ledger-hint">按类目筛选，按班次回溯</text>
  </view>

  <scroll-view class="ops-filter-bar" scroll-x enable-flex show-scrollbar="{{false}}">
    <block wx:for="{{categoryTabs}}" wx:key="key">
      <view
        class="ops-filter-pill {{filterType === item.key ? 'active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onTapFilter">
        <text>{{item.label}}</text>
      </view>
    </block>
  </scroll-view>

  <view wx:if="{{loading}}" class="body-md state-line">加载中…</view>
  <view wx:elif="{{errMsg}}" class="body-md state-line state-err">{{errMsg}}</view>
  <block wx:else>
    <view wx:if="{{!(filteredItems && filteredItems.length)}}" class="body-md state-line ops-empty">
      <text class="ops-empty-title">暂无流水</text>
      <text class="ops-empty-hint">当前筛选下没有记录，切换类目再试</text>
    </view>

    <view class="ops-timeline">
      <view wx:for="{{filteredItems}}" wx:key="id" class="ops-tl-row">
        <view class="ops-tl-rail">
          <view class="ops-tl-dot tone-{{item.tone}}"></view>
          <view class="ops-tl-line"></view>
        </view>

        <view class="ops-tl-body">
          <view class="ops-tl-head">
            <view class="ops-tl-badge tone-{{item.tone}}">
              <text class="ops-tl-badge-initial">{{item.initial}}</text>
              <text class="ops-tl-badge-label">{{item.type_label}}</text>
            </view>
            <text class="ops-tl-time">{{item.time_display || '—'}}</text>
          </view>

          <view wx:if="{{item.has_stock}}" class="ops-tl-metric">
            <text class="ops-tl-metric-label">库存</text>
            <text class="ops-tl-metric-delta {{item.delta > 0 ? 'pos' : (item.delta < 0 ? 'neg' : '')}}">{{item.stock_delta_display}}</text>
            <text class="ops-tl-metric-balance">结余 {{item.balance_after}} 件</text>
          </view>

          <view wx:if="{{item.has_cash}}" class="ops-tl-metric">
            <text class="ops-tl-metric-label">现金</text>
            <text class="ops-tl-metric-delta {{item.cash_delta > 0 ? 'pos' : (item.cash_delta < 0 ? 'neg' : '')}}">{{item.cash_delta_display}}</text>
            <text class="ops-tl-metric-balance">结余 {{item.cash_balance_after}} 円</text>
          </view>

          <view wx:if="{{item.shift_chip || item.operator_display || item.note}}" class="ops-tl-meta">
            <view wx:if="{{item.shift_chip}}" class="ops-tl-chip ops-tl-chip--shift">
              <text class="ops-tl-chip-dot">·</text>
              <text>{{item.shift_chip}}</text>
              <text wx:if="{{item.recorder_name}}" class="ops-tl-chip-sub">{{item.recorder_name}}</text>
            </view>
            <view wx:if="{{item.operator_display}}" class="ops-tl-chip ops-tl-chip--op">
              <text>操作人 {{item.operator_display}}</text>
            </view>
          </view>
          <text wx:if="{{item.note}}" class="ops-tl-note">{{item.note}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{loadingMore}}" class="body-md state-line">加载更多…</view>
    <view wx:elif="{{hasMore && filteredItems.length > 0}}" class="body-md state-line ops-load-more" bindtap="loadMore">
      <text>加载更多</text>
    </view>
    <view wx:elif="{{!hasMore && items.length > 0}}" class="body-md state-line ops-no-more">
      <text>已到底</text>
    </view>
  </block>

  <view class="bottom-spacer"></view>

  <!-- 操作弹窗 -->
  <view wx:if="{{actionModalVisible}}" class="ops-modal-mask" bindtap="closeActionModal">
    <view class="ops-modal-panel" catchtap="noop">
      <view class="ops-modal-head">
        <text class="title-md ops-modal-title">{{actionModalTitle}}</text>
        <text wx:if="{{actionType === 'restock'}}" class="ops-modal-sub">进货款走店外资金，不影响门店现金</text>
        <text wx:elif="{{actionType === 'withdraw'}}" class="ops-modal-sub">从门店现金转出，库存不变</text>
        <text wx:elif="{{actionType === 'adjust_stock'}}" class="ops-modal-sub">用实盘数覆盖当前库存</text>
        <text wx:elif="{{actionType === 'adjust_cash'}}" class="ops-modal-sub">用实盘数覆盖当前现金</text>
      </view>

      <view class="ops-modal-body">
        <block wx:if="{{actionType === 'restock'}}">
          <view class="ops-input-group">
            <text class="label-sm">进货数量（件）</text>
            <input class="ops-input" type="number" placeholder="请输入数量" value="{{actionValStock}}" bindinput="onInputValStock" />
          </view>
        </block>

        <block wx:if="{{actionType === 'withdraw'}}">
          <view class="ops-input-group">
            <text class="label-sm">取现金额（円）</text>
            <input class="ops-input" type="digit" placeholder="请输入取现金额" value="{{actionValCash}}" bindinput="onInputValCash" />
          </view>
        </block>

        <block wx:if="{{actionType === 'adjust_stock'}}">
          <view class="ops-input-group">
            <text class="label-sm">实盘库存（件）</text>
            <input class="ops-input" type="number" placeholder="请输入实盘件数" value="{{actionValStock}}" bindinput="onInputValStock" />
          </view>
        </block>

        <block wx:if="{{actionType === 'adjust_cash'}}">
          <view class="ops-input-group">
            <text class="label-sm">实盘现金（円）</text>
            <input class="ops-input" type="digit" placeholder="请输入实盘现金" value="{{actionValCash}}" bindinput="onInputValCash" />
          </view>
        </block>

        <view class="ops-input-group">
          <text class="label-sm">备注（选填）</text>
          <input class="ops-input" type="text" placeholder="留个理由，方便日后回查" value="{{actionNote}}" bindinput="onInputNote" />
        </view>
      </view>

      <view class="ops-modal-foot">
        <button class="ops-btn ops-btn-cancel" bindtap="closeActionModal">取消</button>
        <button class="ops-btn ops-btn-confirm" bindtap="submitAction">确认</button>
      </view>
    </view>
  </view>
</view>
