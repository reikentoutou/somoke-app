@import '../settings-recorders/settings-recorders.wxss';

.ops-ledger-page {
  padding-top: 8rpx;
}

/* ----- Hero ----- */

.ops-hero {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.ops-hero-card {
  flex: 1;
  padding: 40rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.ops-hero-label {
  margin-bottom: 24rpx;
}

.ops-hero-val-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 8rpx;
}

.ops-hero-val {
  font-size: 64rpx;
  font-weight: 700;
  color: #1a1c1d;
  line-height: 1;
  letter-spacing: -1rpx;
}

.ops-hero-unit {
  font-size: 28rpx;
  font-weight: 600;
  color: #474747;
}

/* ----- Quick actions ----- */

.ops-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 56rpx;
}

.ops-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  border-radius: 32rpx;
  background: #ffffff;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
}

.ops-action-hover {
  background: #f9f9fb;
}

.ops-action-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f3f3f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1c1d;
  margin-bottom: 16rpx;
}

.ops-action-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #474747;
}

/* ----- Section head ----- */

.ops-section-head {
  margin-bottom: 20rpx;
}

.ops-ledger-hint {
  display: block;
  color: #8a8a8f;
  margin-top: 8rpx;
  font-size: 24rpx;
}

/* ----- Category filter pills ----- */

.ops-filter-bar {
  white-space: nowrap;
  margin-bottom: 28rpx;
  padding-bottom: 4rpx;
}

.ops-filter-pill {
  display: inline-block;
  padding: 14rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #474747;
  background: #f2f2f4;
  border: 2rpx solid transparent;
  transition: background 120ms ease;
}

.ops-filter-pill.active {
  background: #16181c;
  color: #ffffff;
  border-color: #16181c;
}

/* ----- Timeline ----- */

.ops-timeline {
  position: relative;
  padding-left: 8rpx;
}

.ops-tl-row {
  position: relative;
  display: flex;
  gap: 20rpx;
  padding-bottom: 28rpx;
}

.ops-tl-row:last-child .ops-tl-line {
  display: none;
}

.ops-tl-rail {
  position: relative;
  width: 20rpx;
  flex-shrink: 0;
  padding-top: 10rpx;
}

.ops-tl-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #1a1c1d;
  border: 4rpx solid #ffffff;
  box-shadow: 0 0 0 2rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 1;
}

.ops-tl-line {
  position: absolute;
  top: 28rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  bottom: -28rpx;
  background: rgba(0, 0, 0, 0.06);
}

.ops-tl-body {
  flex: 1;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ops-tl-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.ops-tl-badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 18rpx 8rpx 8rpx;
  border-radius: 999rpx;
  background: #f3f3f5;
}

.ops-tl-badge-initial {
  display: inline-flex;
  width: 40rpx;
  height: 40rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #1a1c1d;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.ops-tl-badge-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1c1d;
}

.ops-tl-time {
  font-size: 24rpx;
  color: #8a8a8f;
}

/* Tone variants — dot + badge accent */

.ops-tl-dot.tone-record {
  background: #1a1c1d;
}

.ops-tl-dot.tone-restock {
  background: #07c160;
}

.ops-tl-dot.tone-withdraw {
  background: #ba1a1a;
}

.ops-tl-dot.tone-adjust {
  background: #c48200;
}

.ops-tl-badge.tone-record .ops-tl-badge-initial {
  background: #16181c;
}

.ops-tl-badge.tone-restock {
  background: #e6f9ee;
}

.ops-tl-badge.tone-restock .ops-tl-badge-initial {
  background: #07c160;
}

.ops-tl-badge.tone-restock .ops-tl-badge-label {
  color: #065f2f;
}

.ops-tl-badge.tone-withdraw {
  background: #fdeaea;
}

.ops-tl-badge.tone-withdraw .ops-tl-badge-initial {
  background: #ba1a1a;
}

.ops-tl-badge.tone-withdraw .ops-tl-badge-label {
  color: #7a1010;
}

.ops-tl-badge.tone-adjust {
  background: #fff3d9;
}

.ops-tl-badge.tone-adjust .ops-tl-badge-initial {
  background: #c48200;
}

.ops-tl-badge.tone-adjust .ops-tl-badge-label {
  color: #6b4500;
}

/* Metrics */

.ops-tl-metric {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 16rpx;
  background: #fafafb;
  border-radius: 16rpx;
}

.ops-tl-metric-label {
  font-size: 22rpx;
  color: #8a8a8f;
  width: 64rpx;
  flex-shrink: 0;
}

.ops-tl-metric-delta {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1c1d;
  flex: 1;
}

.ops-tl-metric-delta.pos {
  color: #07c160;
}

.ops-tl-metric-delta.neg {
  color: #ba1a1a;
}

.ops-tl-metric-balance {
  font-size: 22rpx;
  color: #6e6e73;
}

/* Meta chips */

.ops-tl-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 4rpx;
}

.ops-tl-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #f3f3f5;
  color: #474747;
}

.ops-tl-chip--shift {
  background: #eef2ff;
  color: #2c3d8f;
}

.ops-tl-chip-dot {
  color: #99a6d3;
}

.ops-tl-chip-sub {
  color: #5b6aa1;
  font-weight: 500;
}

.ops-tl-chip--op {
  background: #f7f3eb;
  color: #6b5425;
}

.ops-tl-note {
  display: block;
  font-size: 24rpx;
  color: #474747;
  line-height: 1.5;
  padding: 4rpx 0;
  border-top: 2rpx dashed rgba(0, 0, 0, 0.06);
  padding-top: 16rpx;
  margin-top: 4rpx;
}

/* Empty state */

.ops-empty {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  padding: 40rpx 0;
}

.ops-empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #474747;
}

.ops-empty-hint {
  font-size: 24rpx;
  color: #8a8a8f;
}

/* ----- Modal ----- */

.ops-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.ops-modal-panel {
  width: 100%;
  background: #ffffff;
  border-radius: 48rpx;
  overflow: hidden;
}

.ops-modal-head {
  padding: 48rpx 48rpx 24rpx;
}

.ops-modal-title {
  font-size: 40rpx;
  font-weight: 700;
}

.ops-modal-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8a8a8f;
  line-height: 1.4;
}

.ops-modal-body {
  padding: 16rpx 48rpx 0;
}

.ops-input-group {
  margin-bottom: 32rpx;
}

.ops-input-group .label-sm {
  display: block;
  margin-bottom: 16rpx;
}

.ops-input {
  width: 100%;
  height: 96rpx;
  background: #f3f3f5;
  border-radius: 24rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  font-size: 32rpx;
  color: #1a1c1d;
}

.ops-modal-foot {
  display: flex;
  flex-direction: row;
  padding: 32rpx 48rpx 48rpx;
  gap: 24rpx;
}

.ops-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  margin: 0;
}

.ops-btn-cancel {
  background: #f3f3f5;
  color: #474747;
}

.ops-btn-confirm {
  background: #16181c;
  color: #ffffff;
}
