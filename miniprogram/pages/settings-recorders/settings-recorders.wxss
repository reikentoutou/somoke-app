.sub-page {
  padding: 32rpx 32rpx 120rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.state-line {
  padding: 48rpx 16rpx;
  text-align: center;
  color: #474747;
}

.state-err {
  color: #ba1a1a;
}

.rec-hint {
  display: block;
  margin-bottom: 32rpx;
  color: #5e5e63;
  line-height: 1.5;
}

.rec-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  margin-bottom: 20rpx;
}

.rec-name {
  flex: 1;
  min-width: 0;
  margin-right: 24rpx;
}

.rec-del {
  flex-shrink: 0;
  color: #ba1a1a;
  padding: 12rpx 20rpx;
}

.rec-del-hover {
  opacity: 0.85;
}

.rec-add-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-top: 40rpx;
}

.rec-add-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  padding: 0 28rpx;
  background-color: #f3f3f5;
  border-radius: 24rpx;
  border: 2rpx solid #e8e8ea;
  box-sizing: border-box;
}

.rec-add-btn {
  flex-shrink: 0;
  padding: 0 36rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  background-color: #000000;
  border-radius: 24rpx;
  text-align: center;
}

.rec-add-btn-hover {
  opacity: 0.9;
}

.footnote {
  display: block;
  margin-top: 40rpx;
  color: #5e5e63;
}

.bottom-spacer {
  height: 80rpx;
}
