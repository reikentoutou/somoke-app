<view class="page-container sub-page">
  <view wx:if="{{loading}}" class="body-md state-line">加载中…</view>
  <view wx:elif="{{errMsg}}" class="body-md state-line state-err">{{errMsg}}</view>
  <block wx:else>
    <text class="body-md rec-hint">录入页将从下列姓名中选择记账人；老板可添加或删除（最多 50 个）。</text>

    <view wx:for="{{names}}" wx:key="*this" class="card rec-row">
      <text class="title-md rec-name">{{item}}</text>
      <text wx:if="{{canEdit}}" class="body-md rec-del" hover-class="rec-del-hover" data-name="{{item}}" bindtap="onDeleteName">删除</text>
    </view>

    <view wx:if="{{!(names && names.length)}}" class="body-md state-line">暂无姓名，请添加。</view>

    <view wx:if="{{canEdit}}" class="rec-add-bar">
      <input class="rec-add-input body-md" maxlength="32" placeholder="新姓名" value="{{newName}}" bindinput="onNewNameInput" />
      <view class="rec-add-btn" hover-class="rec-add-btn-hover" bindtap="onAddName">添加</view>
    </view>

    <text wx:if="{{!canEdit}}" class="body-md footnote">仅门店老板可维护名单。</text>
  </block>
  <view class="bottom-spacer"></view>
</view>
