<view class="page-container profile-edit-page">
  <view class="headline-section">
    <text class="label-sm">显示名称</text>
    <text class="title-md form-title">修改昵称</text>
    <text class="body-md form-desc">保存后将与录入页「记账姓名」一致，并用于报表等处的操作者展示。</text>
  </view>

  <view class="card field-card">
    <text class="label-sm field-label">昵称</text>
    <input
      class="field-input"
      type="text"
      maxlength="64"
      placeholder="请输入昵称"
      value="{{nickname}}"
      bindinput="onNicknameInput"
    />
  </view>

  <button
    class="submit-btn"
    type="primary"
    loading="{{submitting}}"
    disabled="{{submitting}}"
    bindtap="onSubmit"
  >
    保存
  </button>
</view>
