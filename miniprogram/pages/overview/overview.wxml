<view class="page-container overview-page">
  <view class="overview-hero">
    <text class="label-sm overview-hero__label">当日销售营收</text>
    <view class="overview-hero__amount-row">
      <text class="overview-hero__currency">¥</text>
      <text class="overview-hero__amount display-lg">{{totalRevenueStr}}</text>
    </view>
    <view class="overview-sync">
      <view class="overview-sync__dot" />
      <text class="overview-sync__text body-md">实时同步中</text>
    </view>
  </view>

  <view class="overview-channels">
    <view class="overview-channel card">
      <view class="overview-channel__badge overview-channel__badge--wechat" aria-hidden="true" />
      <text class="label-sm overview-channel__label">微信</text>
      <view class="overview-channel__amount-row">
        <text class="overview-channel__currency">¥</text>
        <text class="overview-channel__amount headline-lg">{{wechatAmountStr}}</text>
      </view>
      <text class="overview-channel__meta body-md">{{wechatQty}} 件</text>
    </view>
    <view class="overview-channel card">
      <view class="overview-channel__badge overview-channel__badge--alipay" aria-hidden="true" />
      <text class="label-sm overview-channel__label">支付宝</text>
      <view class="overview-channel__amount-row">
        <text class="overview-channel__currency">¥</text>
        <text class="overview-channel__amount headline-lg">{{alipayAmountStr}}</text>
      </view>
      <text class="overview-channel__meta body-md">{{alipayQty}} 件</text>
    </view>
    <view class="overview-channel card">
      <view class="overview-channel__badge overview-channel__badge--cash" aria-hidden="true" />
      <text class="label-sm overview-channel__label">现金</text>
      <view class="overview-channel__amount-row">
        <text class="overview-channel__currency">¥</text>
        <text class="overview-channel__amount headline-lg">{{cashAmountStr}}</text>
      </view>
      <text class="overview-channel__meta body-md">{{cashQty}} 件</text>
    </view>
  </view>

  <view wx:if="{{showChannelMix}}" class="overview-mix card-low">
    <text class="label-sm overview-mix__label">今日渠道占比（按件数）</text>
    <view class="overview-mix-track">
      <view wx:if="{{payMixW > 0}}" class="overview-mix-seg overview-mix-seg--wechat" style="width: {{payPctW}}%;" />
      <view wx:if="{{payMixA > 0}}" class="overview-mix-seg overview-mix-seg--alipay" style="width: {{payPctA}}%;" />
      <view wx:if="{{payMixC > 0}}" class="overview-mix-seg overview-mix-seg--cash" style="width: {{payPctC}}%;" />
    </view>
    <view class="overview-mix-legend">
      <text class="overview-mix-i w">微信 {{payPctW}}%</text>
      <text class="overview-mix-i a">支付宝 {{payPctA}}%</text>
      <text class="overview-mix-i c">现金 {{payPctC}}%</text>
    </view>
  </view>

  <view class="overview-section">
    <view class="overview-section__head">
      <text class="title-md overview-section__title">班次详情</text>
      <text class="overview-section__link body-md" bindtap="goViewAll">查看全部</text>
    </view>

    <view wx:if="{{(!records || records.length === 0) && !loadError}}" class="overview-empty card-low">
      <text class="body-md overview-empty__text">今日暂无班次记录</text>
    </view>

    <view wx:if="{{loadError}}" class="overview-empty overview-empty--error card-low">
      <text class="body-md overview-empty__text">加载失败，请稍后重试</text>
    </view>

    <view class="overview-shift-list">
      <view
        wx:for="{{records || []}}"
        wx:key="id"
        class="overview-shift-item card"
        bindtap="goShiftDetail"
        data-id="{{item.id}}"
        data-date="{{item.record_date}}"
      >
        <view class="overview-shift-item__icon overview-shift-item__icon--{{item.iconTone}}">
          <text class="overview-shift-item__icon-text">{{item.iconChar}}</text>
        </view>
        <view class="overview-shift-item__main">
          <view class="overview-shift-item__row1">
            <text class="title-md overview-shift-item__name">{{item.shift_name}}</text>
            <text class="overview-shift-item__revenue">¥ {{item.revenueStr}}</text>
          </view>
          <text class="body-md overview-shift-item__time">{{item.timeRange}}</text>
          <view class="overview-shift-item__row3">
            <text class="body-md overview-shift-item__recorder">{{item.recorder_name}}</text>
            <text class="body-md overview-shift-item__qty">已售 {{item.qty_sold}} 件</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-spacer" />
</view>
