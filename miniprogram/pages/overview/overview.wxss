/* 概览页 — Digital Ledger 单色系 */

.overview-page {
  padding-top: 32rpx;
}

/* ----- Hero ----- */

.overview-hero {
  margin-bottom: 48rpx;
}

.overview-hero__label {
  display: block;
  margin-bottom: 16rpx;
}

.overview-hero__amount-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 12rpx 16rpx;
  margin-bottom: 24rpx;
}

.overview-hero__currency {
  font-size: 48rpx;
  font-weight: 600;
  color: #000000;
  letter-spacing: -1rpx;
  line-height: 1;
}

.overview-hero__amount {
  letter-spacing: -4rpx;
}

/* 实时同步 */

.overview-sync {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.overview-sync__dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #000000;
  box-shadow: 0 0 0 6rpx rgba(0, 0, 0, 0.06);
  animation: overview-sync-pulse 2s ease-in-out infinite;
}

@keyframes overview-sync-pulse {
  0%,
  100% {
    opacity: 1;
    transform: scale(1);
    box-shadow: 0 0 0 6rpx rgba(0, 0, 0, 0.06);
  }
  50% {
    opacity: 0.85;
    transform: scale(0.92);
    box-shadow: 0 0 0 12rpx rgba(0, 0, 0, 0.04);
  }
}

.overview-sync__text {
  color: #5e5e63;
  font-size: 26rpx;
}

/* ----- Channel cards ----- */

.overview-channels {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 56rpx;
}

.overview-channel {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  min-height: 200rpx;
}

.overview-channel__label {
  margin-bottom: 20rpx;
}

.overview-channel__amount-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 6rpx;
  margin-bottom: 12rpx;
}

.overview-channel__currency {
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
}

.overview-channel__amount {
  font-size: 56rpx;
  line-height: 1.1;
}

.overview-channel__meta {
  margin-top: auto;
  color: #474747;
  font-size: 24rpx;
}

/* ----- Section ----- */

.overview-section {
  margin-bottom: 32rpx;
}

.overview-section__head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding: 0 4rpx;
}

.overview-section__title {
  letter-spacing: -0.5rpx;
}

.overview-section__link {
  color: #000000;
  font-weight: 500;
  text-decoration: underline;
  text-underline-offset: 6rpx;
  text-decoration-color: rgba(0, 0, 0, 0.25);
}

/* Empty states */

.overview-empty {
  padding: 56rpx 48rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.overview-empty__text {
  color: #5e5e63;
}

.overview-empty--error .overview-empty__text {
  color: #ba1a1a;
}

/* ----- Shift list ----- */

.overview-shift-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.overview-shift-item {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 28rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  transition: background-color 0.15s ease;
}

.overview-shift-item:active {
  background-color: #f9f9fb;
}

.overview-shift-item__icon {
  width: 96rpx;
  height: 96rpx;
  min-width: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  align-self: center;
  border: 2rpx solid rgba(0, 0, 0, 0.06);
}

.overview-shift-item__icon-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1c1d;
  line-height: 1;
}

/* 班次色调：低调单色层次 */

.overview-shift-item__icon--morning {
  background: linear-gradient(145deg, #f3f3f5 0%, #e8e8ea 100%);
}

.overview-shift-item__icon--day {
  background: linear-gradient(145deg, #ffffff 0%, #f3f3f5 100%);
}

.overview-shift-item__icon--night {
  background: linear-gradient(145deg, #e8e8ea 0%, #d8d8dc 100%);
}

.overview-shift-item__icon--neutral {
  background: #f3f3f5;
}

.overview-shift-item__main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.overview-shift-item__row1 {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.overview-shift-item__name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.overview-shift-item__revenue {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  letter-spacing: -0.5rpx;
  flex-shrink: 0;
}

.overview-shift-item__time {
  font-size: 24rpx;
  color: #5e5e63;
  letter-spacing: 0.5rpx;
}

.overview-shift-item__row3 {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 4rpx;
}

.overview-shift-item__recorder,
.overview-shift-item__qty {
  font-size: 24rpx;
  color: #474747;
}

.overview-shift-item__qty {
  color: #5e5e63;
}
