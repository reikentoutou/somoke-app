<view class="page-container">

  <view class="headline-section">
    <text class="label-sm">{{entryTagLabel}}</text>
    <text class="headline-lg">{{entryTitle}}</text>
    <text wx:if="{{isEditMode}}" class="body-md entry-cancel" bindtap="cancelEdit">取消修改</text>
  </view>

  <ledger-record-form id="form" bind:submitsuccess="onFormSuccess" />

  <view class="bottom-spacer"></view>
</view>
