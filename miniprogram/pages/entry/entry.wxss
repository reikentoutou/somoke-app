/* ===== Entry Page: 录入页 ===== */

.headline-section {
  margin-bottom: 80rpx;
}

.entry-cancel {
  display: block;
  margin-top: 16rpx;
  color: #666666;
  text-decoration: underline;
}

.headline-section .label-sm {
  display: block;
  margin-bottom: 8rpx;
}

/* ===== Date & Shift Pickers ===== */

.picker-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 60rpx;
}

.picker-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 40rpx;
}

.picker-card .label-sm {
  margin-bottom: 24rpx;
}

.picker-value {
  font-size: 40rpx;
  font-weight: 500;
  color: #000000;
}

.picker-value--empty {
  font-weight: 400;
  color: #888888;
}

/* ===== Recorder Name ===== */

.name-section {
  margin-bottom: 60rpx;
}

.name-section .label-sm {
  display: block;
  margin-bottom: 12rpx;
}

.name-picker-display {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #c6c6c6;
}

.name-display-text {
  font-size: 48rpx;
  font-weight: 600;
  color: #000000;
}

.name-picker-chev {
  font-size: 40rpx;
  color: #c6c6c6;
  padding-left: 16rpx;
}

/* ===== Quantity Section ===== */

.qty-card {
  margin-bottom: 60rpx;
  padding: 48rpx;
}

.qty-row {
  display: flex;
  align-items: stretch;
}

.qty-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.qty-col.right {
  text-align: right;
}

.qty-label {
  display: block;
  margin-bottom: 12rpx;
  text-align: center;
}

.qty-label.right {
  text-align: center;
}

.qty-input {
  width: 100%;
  height: 96rpx;
  min-height: 96rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 96rpx;
  color: #000000;
  text-align: center;
  background: transparent;
}

.qty-input.right {
  text-align: center;
}

.qty-divider {
  width: 2rpx;
  align-self: center;
  min-height: 96rpx;
  height: 96rpx;
  background: rgba(198, 198, 198, 0.3);
  margin: 0 24rpx;
  flex-shrink: 0;
}

/* ===== Payment Methods ===== */

.payment-section {
  margin-bottom: 60rpx;
}

.payment-section .title-md {
  display: block;
  margin-bottom: 32rpx;
}

.pay-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx;
  margin-bottom: 16rpx;
}

.pay-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.pay-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
}

.pay-icon.wechat  { background: #07C160; }
.pay-icon.alipay  { background: #1677FF; }
.pay-icon.cash    { background: #000000; }
.pay-icon.gift-icon { background: #ba1a1a; }

.pay-name {
  font-size: 30rpx;
  font-weight: 500;
}

.pay-name.err {
  color: #ba1a1a;
}

.pay-input {
  width: 160rpx;
  text-align: right;
  font-size: 36rpx;
  font-weight: 600;
  background: transparent;
}

.pay-input.err {
  color: #ba1a1a;
}

/* ===== Summary Card (Dark) ===== */

.summary-card {
  background: #000000;
  color: #e2e2e2;
  padding: 48rpx;
  border-radius: 48rpx;
  margin-bottom: 60rpx;
  box-shadow: 0 40rpx 80rpx rgba(0, 0, 0, 0.1);
}

.summary-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  opacity: 0.6;
  margin-bottom: 36rpx;
}

.summary-main {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding-bottom: 28rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.1);
  margin-bottom: 28rpx;
}

.summary-main-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-end;
  width: 100%;
}

.summary-formula {
  display: block;
  font-size: 22rpx;
  line-height: 1.45;
  opacity: 0.55;
  margin-top: 16rpx;
}

.summary-hint {
  font-size: 28rpx;
  opacity: 0.8;
}

.summary-big {
  font-size: 60rpx;
  font-weight: 700;
  letter-spacing: -2rpx;
}

.summary-revenue-block {
  margin-bottom: 28rpx;
  padding-bottom: 28rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.1);
}

.summary-hint-rev {
  display: block;
  margin-bottom: 12rpx;
}

.summary-revenue-jpy {
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.summary-inventory-hint {
  margin-bottom: 8rpx;
}

.summary-inventory-text {
  font-size: 22rpx;
  line-height: 1.45;
  opacity: 0.5;
}

.soft-warn-box {
  margin-top: 24rpx;
  margin-bottom: 8rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background-color: rgba(255, 183, 77, 0.14);
  border: 2rpx solid rgba(255, 183, 77, 0.35);
}

.soft-warn-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #ffb84d;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.soft-warn-line {
  display: block;
  font-size: 24rpx;
  line-height: 1.55;
  color: rgba(255, 224, 180, 0.95);
  margin-bottom: 12rpx;
}

.soft-warn-line:last-child {
  margin-bottom: 0;
}

.summary-grid {
  display: flex;
  gap: 48rpx;
  padding-top: 12rpx;
}

.summary-col {
  flex: 1;
}

.summary-col.right {
  text-align: right;
}

.summary-sub-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  opacity: 0.6;
  margin-bottom: 8rpx;
}

.summary-input {
  width: 100%;
  font-size: 40rpx;
  font-weight: 600;
  color: #e2e2e2;
  background: transparent;
}

.summary-input.right {
  text-align: right;
}

/* ===== Submit Button ===== */

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  padding: 40rpx 0;
  background: #000000;
  color: #e2e2e2;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  transition: all 0.2s;
}

.submit-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.submit-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.arrow {
  font-size: 36rpx;
}
