/* Settings — Design tokens aligned with app global palette */

.settings-shell.page-container {
  padding: 0 32rpx 240rpx;
  background-color: #f9f9fb;
  box-sizing: border-box;
  min-height: 100vh;
}

/* ----- Profile ----- */

.settings-profile {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  margin-bottom: 40rpx;
  padding: 40rpx 48rpx;
}

.settings-profile-main {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.settings-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background-color: #f3f3f5;
  border: 2rpx solid #e8e8ea;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 600;
  color: #000000;
  flex-shrink: 0;
}

.settings-profile-text {
  margin-left: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.settings-profile-name {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.settings-profile-role {
  display: block;
  color: #474747;
}

.settings-chevron {
  font-size: 40rpx;
  font-weight: 300;
  color: #000000;
  line-height: 1;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.settings-chevron.muted {
  color: #c6c6c6;
}

/* ----- Group labels ----- */

.settings-group-label {
  display: block;
  margin: 32rpx 8rpx 16rpx;
}

/* ----- Card list ----- */

.settings-card {
  background: #ffffff;
  border-radius: 48rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.03);
  overflow: hidden;
  margin-bottom: 8rpx;
}

.settings-row {
  display: flex;
  align-items: center;
  padding: 28rpx 40rpx;
  min-height: 96rpx;
  box-sizing: border-box;
}

.settings-row-nested {
  padding: 0 0 16rpx;
  min-height: 0;
}

.settings-row-tall {
  align-items: flex-start;
  padding-top: 32rpx;
  padding-bottom: 32rpx;
}

.settings-row-stack {
  flex-direction: column;
  align-items: stretch;
  padding: 28rpx 40rpx 32rpx;
}

.settings-col-grow {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
  margin-right: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.settings-divider {
  height: 2rpx;
  background-color: #f3f3f5;
  margin-left: 40rpx;
  margin-right: 40rpx;
}

.settings-icon-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #f3f3f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #474747;
  flex-shrink: 0;
}

.settings-row-label {
  color: #000000;
  font-weight: 500;
}

.settings-row > .settings-row-label {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
  margin-right: 16rpx;
}

.settings-row-tall .settings-col-grow .settings-row-label {
  margin-left: 0;
}

.settings-row-trailing {
  flex-shrink: 0;
  max-width: 46%;
  color: #474747;
  font-size: 26rpx;
  text-align: right;
  margin-right: 8rpx;
}

.settings-sub {
  color: #474747;
  font-size: 26rpx;
}

.settings-withdraw-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.settings-edit-glyph {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background-color: #f3f3f5;
  border: 2rpx solid #e8e8ea;
  font-size: 22rpx;
  color: #474747;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

/* ----- Restock ----- */

.settings-restock {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 0 0 8rpx;
  margin-top: 8rpx;
}

.settings-restock-input {
  flex: 1;
  height: 72rpx;
  padding: 0 28rpx;
  background-color: #f3f3f5;
  border-radius: 24rpx;
  border: 2rpx solid #e8e8ea;
  color: #1a1c1d;
  box-sizing: border-box;
}

.settings-restock-btn {
  margin: 0 !important;
  padding: 0 36rpx !important;
  height: 72rpx !important;
  line-height: 72rpx !important;
  background-color: #000000 !important;
  color: #e2e2e4 !important;
  border-radius: 24rpx !important;
  font-size: 26rpx !important;
  font-weight: 500;
  border: none !important;
}

.settings-restock-btn::after {
  border: none;
}

/* ----- Logout & version ----- */

.settings-logout {
  width: 100%;
  margin-top: 48rpx;
  padding: 28rpx;
  background: transparent !important;
  border: none !important;
  color: #ba1a1a !important;
  font-weight: 500;
}

.settings-logout::after {
  border: none;
}

.settings-version {
  display: block;
  text-align: center;
  margin-top: 32rpx;
  color: #c6c6c6;
  font-size: 24rpx;
}
