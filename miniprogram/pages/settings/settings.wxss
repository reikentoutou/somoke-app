/* Settings — Design tokens aligned with app global palette */

.settings-shell.page-container {
  padding: 0 32rpx 240rpx;
  background-color: #f9f9fb;
  box-sizing: border-box;
  min-height: 100vh;
}

/* ----- Profile ----- */

.settings-profile {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  margin-bottom: 40rpx;
  padding: 40rpx 48rpx;
}

.settings-profile-main {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.settings-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background-color: #f3f3f5;
  border: 2rpx solid #e8e8ea;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 600;
  color: #000000;
  flex-shrink: 0;
}

.settings-profile-text {
  margin-left: 32rpx;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.settings-profile-name {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.settings-profile-role {
  display: block;
  color: #474747;
  margin-bottom: 6rpx;
}

.settings-profile-hint {
  display: block;
  font-size: 22rpx;
  color: #5e5e63;
  line-height: 1.35;
}

.settings-profile-hover {
  opacity: 0.92;
}

.settings-profile-arrow {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.settings-profile-trailing {
  flex-shrink: 0;
  max-width: 40%;
  color: #474747;
  font-size: 26rpx;
  text-align: right;
  margin-right: 8rpx;
}

.settings-chevron {
  font-size: 40rpx;
  font-weight: 300;
  color: #000000;
  line-height: 1;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.settings-chevron.muted {
  color: #c6c6c6;
}

/* ----- Group labels ----- */

.settings-group-label {
  display: block;
  margin: 32rpx 8rpx 16rpx;
}

/* ----- Card list ----- */

.settings-card {
  background: #ffffff;
  border-radius: 48rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.03);
  overflow: hidden;
  margin-bottom: 8rpx;
}

.settings-row {
  display: flex;
  align-items: center;
  padding: 28rpx 40rpx;
  min-height: 96rpx;
  box-sizing: border-box;
}

.settings-row-hover {
  opacity: 0.88;
}

.settings-row-nested {
  padding: 0 0 16rpx;
  min-height: 0;
}

.settings-row-tall {
  align-items: flex-start;
  padding-top: 32rpx;
  padding-bottom: 32rpx;
}

.settings-row-stack {
  flex-direction: column;
  align-items: stretch;
  padding: 28rpx 40rpx 32rpx;
}

.settings-col-grow {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
  margin-right: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.settings-divider {
  height: 2rpx;
  background-color: #f3f3f5;
  margin-left: 40rpx;
  margin-right: 40rpx;
}

.settings-icon-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #f3f3f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #474747;
  flex-shrink: 0;
}

.settings-row-label {
  color: #000000;
  font-weight: 500;
}

.settings-row > .settings-row-label {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
  margin-right: 16rpx;
}

.settings-row-tall .settings-col-grow .settings-row-label {
  margin-left: 0;
}

.settings-row-trailing {
  flex-shrink: 0;
  max-width: 46%;
  color: #474747;
  font-size: 26rpx;
  text-align: right;
  margin-right: 8rpx;
}

.settings-sub {
  color: #474747;
  font-size: 26rpx;
}

.settings-sub-reconcile {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #5e5e63;
}

/* ----- Restock ----- */

.settings-restock {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 0 0 8rpx;
  margin-top: 8rpx;
}

.settings-restock-input {
  flex: 1;
  height: 72rpx;
  padding: 0 28rpx;
  background-color: #f3f3f5;
  border-radius: 24rpx;
  border: 2rpx solid #e8e8ea;
  color: #1a1c1d;
  box-sizing: border-box;
}

.settings-restock-btn {
  margin: 0 !important;
  padding: 0 36rpx !important;
  height: 72rpx !important;
  line-height: 72rpx !important;
  background-color: #000000 !important;
  color: #e2e2e4 !important;
  border-radius: 24rpx !important;
  font-size: 26rpx !important;
  font-weight: 500;
  border: none !important;
}

.settings-restock-btn::after {
  border: none;
}

/* ----- 取现 ----- */

.settings-withdraw-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 0 0 8rpx;
  margin-top: 8rpx;
}

.settings-withdraw-input {
  flex: 1;
  height: 72rpx;
  padding: 0 28rpx;
  background-color: #f3f3f5;
  border-radius: 24rpx;
  border: 2rpx solid #e8e8ea;
  color: #1a1c1d;
  box-sizing: border-box;
}

.settings-withdraw-btn {
  margin: 0 !important;
  padding: 0 28rpx !important;
  height: 72rpx !important;
  line-height: 72rpx !important;
  background-color: #000000 !important;
  color: #e2e2e4 !important;
  border-radius: 24rpx !important;
  font-size: 26rpx !important;
  font-weight: 500;
  border: none !important;
}

.settings-withdraw-btn::after {
  border: none;
}

.withdraw-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background-color: rgba(26, 28, 29, 0.5);
  z-index: 10040;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.withdraw-panel {
  width: 100%;
  max-width: 640rpx;
  max-height: 70vh;
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 36rpx 32rpx 28rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
}

.withdraw-panel-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.withdraw-panel-title {
  flex: 1;
  min-width: 0;
  margin-bottom: 0;
}

.withdraw-copy-btn {
  flex-shrink: 0;
  color: #000000;
  font-weight: 500;
  padding: 8rpx 12rpx;
}

.withdraw-summary-box {
  padding: 20rpx 16rpx 28rpx;
  margin-bottom: 8rpx;
  background-color: #f9f9fb;
  border-radius: 16rpx;
  border: 2rpx solid #ececee;
}

.withdraw-summary-line {
  display: block;
  color: #474747;
  line-height: 1.55;
  margin-bottom: 12rpx;
}

.withdraw-summary-line:last-child {
  margin-bottom: 0;
}

.withdraw-scroll {
  flex: 1;
  min-height: 120rpx;
  max-height: 52vh;
  margin-bottom: 24rpx;
}

.withdraw-line {
  display: block;
  padding: 16rpx 8rpx;
  border-bottom: 2rpx solid #f3f3f5;
  color: #1a1c1d;
  line-height: 1.5;
}

.withdraw-panel-close {
  text-align: center;
  color: #5e5e63;
  padding: 16rpx;
}

/* ----- Logout & version ----- */

.settings-logout {
  width: 100%;
  margin-top: 48rpx;
  padding: 28rpx;
  background: transparent !important;
  border: none !important;
  color: #ba1a1a !important;
  font-weight: 500;
}

.settings-logout::after {
  border: none;
}

.settings-version {
  display: block;
  text-align: center;
  margin-top: 32rpx;
  color: #c6c6c6;
  font-size: 24rpx;
}

/* ----- 当前门店（跳转「我的门店」页） ----- */

.settings-row-store {
  align-items: center;
}

.settings-row-store .settings-col-grow {
  margin-left: 24rpx;
  margin-right: 16rpx;
}

.settings-row-tall > .settings-row-trailing,
.settings-row-tall > .settings-chevron {
  align-self: center;
}
