.login-page {
  min-height: 100vh;
  padding: 120rpx 48rpx 48rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.login-label {
  margin-bottom: 16rpx;
}

.login-title {
  margin-bottom: 24rpx;
  font-size: 56rpx;
  font-weight: 700;
}

.login-desc {
  color: #474747;
  margin-bottom: 80rpx;
  line-height: 1.6;
}

.login-btn {
  width: 100% !important;
  background: #000 !important;
  color: #fff !important;
  border-radius: 16rpx !important;
  font-weight: 600;
  padding: 28rpx 0 !important;
}
