<view class="page-container">

  <view class="month-picker-row">
    <view class="month-picker-head">
      <text class="label-sm month-picker-label">查询月份</text>
      <text class="month-picker-sub body-md">选择后加载该月报表与明细</text>
    </view>
    <picker mode="date" fields="month" value="{{monthPickerValue}}" bindchange="onMonthChange">
      <view class="card month-picker-card">
        <view class="month-picker-card-main">
          <text class="month-picker-value">{{currentMonth}}</text>
          <text class="month-picker-hint">点击更改 ›</text>
        </view>
      </view>
    </picker>
  </view>

  <view class="reports-hero">
    <text class="label-sm hero-label">{{heroMonthLabel}}</text>
    <view class="hero-amount-row">
      <text class="hero-currency">¥</text>
      <text class="hero-amount">{{revenueFormatted}}</text>
    </view>
    <view class="hero-sync">
      <view class="hero-sync-dot"></view>
      <text class="body-md hero-sync-text">以下为当前选中月份的统计数据</text>
    </view>
  </view>

  <view class="metrics-grid">
    <view class="card metric-card">
      <view class="metric-icon metric-icon-wechat">
        <view class="metric-icon-bar"></view>
        <view class="metric-icon-bar short"></view>
      </view>
      <text class="label-sm metric-title">微信总计</text>
      <text class="metric-amount">¥ {{wechatAmountFmt}}</text>
      <text class="body-md metric-sub">{{summary.total_wechat_qty}} 件成交</text>
    </view>
    <view class="card metric-card">
      <view class="metric-icon metric-icon-alipay">
        <view class="metric-icon-ring"></view>
      </view>
      <text class="label-sm metric-title">支付宝总计</text>
      <text class="metric-amount">¥ {{alipayAmountFmt}}</text>
      <text class="body-md metric-sub">{{summary.total_alipay_qty}} 件成交</text>
    </view>
    <view class="card metric-card">
      <view class="metric-icon metric-icon-cash">
        <view class="metric-icon-note"></view>
      </view>
      <text class="label-sm metric-title">现金总计</text>
      <text class="metric-amount">¥ {{cashAmountFmt}}</text>
      <text class="body-md metric-sub">{{summary.total_cash_qty}} 件成交</text>
    </view>
  </view>

  <view class="section-head">
    <text class="title-md section-title">营收趋势</text>
  </view>
  <view class="card-low chart-card">
    <view class="chart-toggle-row">
      <view
        class="chart-toggle {{chartMode === 'daily' ? 'active' : ''}}"
        hover-class="chart-toggle-hover"
        bindtap="onChartModeDaily"
      >按日</view>
      <view
        class="chart-toggle {{chartMode === 'weekly' ? 'active' : ''}}"
        hover-class="chart-toggle-hover"
        bindtap="onChartModeWeekly"
      >按周</view>
    </view>
    <view class="chart-bars" wx:if="{{chartData && chartData.length}}">
      <view
        class="chart-col"
        wx:for="{{chartData || []}}"
        wx:key="chartKey"
        hover-class="chart-col-hover"
        hover-stay-time="80"
      >
        <text class="chart-amount-label">{{item.amountFmt}}</text>
        <view class="chart-bar-track">
          <view class="chart-bar-fill" style="height: {{item.heightPct}}%;"></view>
        </view>
        <text class="chart-day-label">{{item.label}}</text>
        <text class="chart-sublabel" wx:if="{{item.sublabel}}">{{item.sublabel}}</text>
      </view>
    </view>
    <view class="chart-empty body-md" wx:else>本月暂无数据</view>
  </view>

  <view class="section-head section-head-spaced section-head--with-filter">
    <view class="section-head__row">
      <text class="title-md section-title">每日班次明细</text>
    </view>
    <view class="day-filter-bar">
      <view
        class="day-filter-chip {{!detailFilterDate ? 'day-filter-chip--on' : ''}}"
        hover-class="day-filter-chip-hover"
        bindtap="onClearDetailDayFilter"
      >全部日期</view>
      <picker
        class="day-filter-picker-wrap"
        mode="date"
        value="{{detailDayPickerValue}}"
        start="{{monthDayPickStart}}"
        end="{{monthDayPickEnd}}"
        bindchange="onDetailDayPick"
      >
        <view class="day-filter-chip {{detailFilterDate ? 'day-filter-chip--on' : ''}}">
          <text>{{detailFilterDate ? detailFilterLabel : '指定日期'}}</text>
          <text class="day-filter-chip__chev">›</text>
        </view>
      </picker>
    </view>
  </view>

  <block wx:for="{{dailyGroups || []}}" wx:key="date" wx:for-item="group">
    <view class="date-group">
      <view class="date-group-header">
        <text class="date-big">{{group.dateDisplay}}</text>
        <text class="date-weekday body-md">{{group.weekday}}</text>
      </view>
      <view class="card shift-list-card">
        <block wx:for="{{group.items}}" wx:key="id" wx:for-item="shift">
          <view
            class="shift-item shift-item--tap"
            hover-class="shift-item-hover"
            bindtap="goShiftDetail"
            data-id="{{shift.id}}"
            data-date="{{group.date}}"
          >
            <view class="shift-item-top">
              <text class="shift-name">{{shift.shift_name}}</text>
              <text class="shift-revenue">¥ {{shift.revenueFormatted}}</text>
            </view>
            <text class="body-md shift-qty">售出 {{shift.qty_sold}} 件</text>
            <view class="shift-pay-row">
              <text class="pay-pill">微信 ¥ {{shift.wechatAmtFmt}}</text>
              <text class="pay-pill">支付宝 ¥ {{shift.alipayAmtFmt}}</text>
              <text class="pay-pill">现金 ¥ {{shift.cashAmtFmt}}</text>
            </view>
          </view>
          <view class="shift-divider" wx:if="{{index < group.items.length - 1}}"></view>
        </block>
      </view>
    </view>
  </block>

  <view class="list-empty body-md" wx:if="{{!dailyGroups.length && !loading && !detailFilterDate}}">本月暂无班次记录</view>
  <view class="list-empty body-md" wx:if="{{!dailyGroups.length && !loading && detailFilterDate}}">该日暂无班次记录</view>

  <view class="bottom-spacer"></view>
</view>
