/* 报表页 — 与 Design System 单色编辑风格一致 */

/* ----- 月份选择 ----- */

.month-picker-row {
  margin-bottom: 48rpx;
}

.month-picker-label {
  display: block;
  margin-bottom: 16rpx;
}

.month-picker-card {
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.month-picker-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #000000;
  letter-spacing: -1rpx;
}

.month-picker-hint {
  font-size: 24rpx;
  color: #474747;
}

/* ----- Hero ----- */

.reports-hero {
  margin-bottom: 56rpx;
}

.hero-label {
  display: block;
  margin-bottom: 20rpx;
}

.hero-amount-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.hero-currency {
  font-size: 72rpx;
  font-weight: 700;
  color: #000000;
  margin-right: 12rpx;
  letter-spacing: -2rpx;
}

.hero-amount {
  font-size: 120rpx;
  font-weight: 800;
  line-height: 0.95;
  color: #000000;
  letter-spacing: -4rpx;
}

.hero-sync {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.hero-sync-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #000000;
  flex-shrink: 0;
}

.hero-sync-text {
  color: #474747;
  font-size: 26rpx;
}

/* ----- 指标卡片 ----- */

/* 宽屏三列，窄屏自动折行堆叠 */
.metrics-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 64rpx;
}

.metric-card {
  flex: 1 1 200rpx;
  min-width: 200rpx;
  max-width: 100%;
  box-sizing: border-box;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  border-radius: 48rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.metric-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #f3f3f5;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
  position: relative;
  box-sizing: border-box;
}

.metric-icon-wechat {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: center;
  gap: 8rpx;
  padding-bottom: 12rpx;
}

.metric-icon-bar {
  width: 10rpx;
  height: 28rpx;
  background: #000000;
  border-radius: 4rpx;
}

.metric-icon-bar.short {
  height: 18rpx;
}

.metric-icon-alipay {
  display: flex;
  align-items: center;
  justify-content: center;
}

.metric-icon-ring {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 4rpx solid #000000;
  box-sizing: border-box;
}

.metric-icon-cash {
  display: flex;
  align-items: center;
  justify-content: center;
}

.metric-icon-note {
  width: 32rpx;
  height: 22rpx;
  background: #000000;
  border-radius: 4rpx;
}

.metric-title {
  margin-bottom: 8rpx;
}

.metric-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1c1d;
  letter-spacing: -0.5rpx;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.metric-sub {
  font-size: 22rpx;
  color: #474747;
  line-height: 1.35;
}

/* ----- 区块标题 ----- */

.section-head {
  margin-bottom: 24rpx;
}

.section-head-spaced {
  margin-top: 16rpx;
}

.section-title {
  letter-spacing: -0.5rpx;
}

/* ----- 柱状图 ----- */

.chart-card {
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  margin-bottom: 48rpx;
}

.chart-toggle-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.chart-toggle {
  flex: 1;
  text-align: center;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #474747;
  background: #ffffff;
  border: 2rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 999rpx;
  line-height: 1.2;
  box-sizing: border-box;
}

.chart-toggle.active {
  color: #ffffff;
  background: #000000;
  border-color: #000000;
}

.chart-toggle-hover {
  opacity: 0.85;
}

.chart-bars {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12rpx;
  min-height: 320rpx;
  padding-top: 8rpx;
}

.chart-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.chart-col-hover {
  opacity: 0.92;
}

.chart-amount-label {
  font-size: 18rpx;
  font-weight: 600;
  color: #474747;
  margin-bottom: 12rpx;
  text-align: center;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chart-bar-track {
  width: 100%;
  max-width: 72rpx;
  height: 220rpx;
  background: #e2e2e4;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.chart-bar-fill {
  width: 100%;
  min-height: 0;
  background: #000000;
  border-radius: 20rpx;
  transition: height 0.35s ease-out;
}

.chart-day-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #1a1c1d;
  text-align: center;
}

.chart-sublabel {
  font-size: 18rpx;
  color: #474747;
  margin-top: 4rpx;
  text-align: center;
}

.chart-empty {
  text-align: center;
  padding: 48rpx 0;
  color: #474747;
}

/* ----- 按日分组 ----- */

.date-group {
  margin-bottom: 48rpx;
}

.date-group-header {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.date-big {
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1;
  color: #000000;
  letter-spacing: -3rpx;
}

.date-weekday {
  color: #474747;
  font-size: 28rpx;
}

.shift-list-card {
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  padding: 8rpx 40rpx;
}

.shift-item {
  padding: 32rpx 0;
}

.shift-item-top {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.shift-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  flex: 1;
  min-width: 0;
}

.shift-revenue {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1c1d;
  flex-shrink: 0;
}

.shift-qty {
  display: block;
  margin-bottom: 20rpx;
  color: #474747;
}

.shift-pay-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pay-pill {
  font-size: 22rpx;
  color: #1a1c1d;
  background: #f3f3f5;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
}

.shift-divider {
  height: 2rpx;
  background: rgba(0, 0, 0, 0.06);
  margin: 0;
}

.list-empty {
  text-align: center;
  padding: 64rpx 0;
  color: #474747;
}
