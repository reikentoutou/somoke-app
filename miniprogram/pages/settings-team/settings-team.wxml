<view class="page-container sub-page">
  <view wx:if="{{loading}}" class="body-md state-line">加载中…</view>
  <view wx:elif="{{errMsg}}" class="body-md state-line state-err">{{errMsg}}</view>
  <block wx:else>
    <view wx:if="{{!members.length}}" class="body-md state-line">暂无成员</view>
    <view wx:for="{{members}}" wx:key="user_id" class="card member-card">
      <view class="member-row">
        <text class="title-md member-name">{{item.nickname}}</text>
        <text class="label-sm role-pill">{{item.role_name}}</text>
      </view>
      <view class="member-actions" wx:if="{{canEdit}}">
        <text
          wx:if="{{item.user_id !== myUserId}}"
          class="member-action member-action--danger"
          hover-class="member-action-hover"
          data-user-id="{{item.user_id}}"
          bindtap="onRemoveMember"
        >移除</text>
        <text
          wx:if="{{item.role === 2}}"
          class="member-action"
          hover-class="member-action-hover"
          data-user-id="{{item.user_id}}"
          bindtap="onSetBoss"
        >设为管理员</text>
        <text
          wx:if="{{item.role === 1 && item.user_id !== myUserId && bossCount > 1}}"
          class="member-action"
          hover-class="member-action-hover"
          data-user-id="{{item.user_id}}"
          bindtap="onSetStaff"
        >设为员工</text>
      </view>
      <view
        wx:if="{{!canEdit && item.user_id === myUserId && item.role === 2}}"
        class="member-actions"
      >
        <text class="member-action member-action--danger" hover-class="member-action-hover" bindtap="onLeaveStore">退出门店</text>
      </view>
      <view
        wx:if="{{canEdit && item.user_id === myUserId && bossCount > 1}}"
        class="member-actions"
      >
        <text class="member-action member-action--danger" hover-class="member-action-hover" bindtap="onLeaveStore">退出门店</text>
      </view>
    </view>
    <text class="body-md footnote">邀请新员工：在设置页使用「生成邀请码」。</text>
  </block>
  <view class="bottom-spacer"></view>
</view>
