<view class="page-container store-form-page">
  <view class="headline-section">
    <text class="label-sm">邀请码</text>
    <text class="title-md form-title">加入门店</text>
    <text class="body-md form-desc">向门店管理员索取邀请码；提交字段需与后端 join_store 接口一致。</text>
  </view>

  <view class="card field-card">
    <text class="label-sm field-label">邀请码</text>
    <input
      class="field-input"
      placeholder="请输入邀请码"
      value="{{inviteCode}}"
      bindinput="onCodeInput"
    />
  </view>

  <button
    class="submit-btn"
    type="primary"
    loading="{{submitting}}"
    disabled="{{submitting}}"
    bindtap="onSubmit"
  >
    加入并进入首页
  </button>
</view>
