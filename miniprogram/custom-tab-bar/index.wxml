<view class="tab-bar">
  <view wx:for="{{list}}" wx:key="index"
        class="tab-item {{selected === index ? 'active' : ''}}"
        data-index="{{index}}" bindtap="switchTab">

    <!-- 概览: 2×2 网格 -->
    <view class="tab-icon" wx:if="{{item.icon === 'grid'}}">
      <view class="i-grid">
        <view class="g"></view><view class="g"></view>
        <view class="g"></view><view class="g"></view>
      </view>
    </view>

    <!-- 录入: 圆圈 + 十字 -->
    <view class="tab-icon" wx:elif="{{item.icon === 'plus'}}">
      <view class="i-circle">
        <view class="cross-h"></view>
        <view class="cross-v"></view>
      </view>
    </view>

    <!-- 报表: 三根柱形 -->
    <view class="tab-icon" wx:elif="{{item.icon === 'chart'}}">
      <view class="i-bars">
        <view class="b" style="height: 50%"></view>
        <view class="b" style="height: 85%"></view>
        <view class="b" style="height: 38%"></view>
      </view>
    </view>

    <!-- 设置: 三条滑杆 -->
    <view class="tab-icon" wx:elif="{{item.icon === 'sliders'}}">
      <view class="i-sliders">
        <view class="sl"><view class="dot" style="left: 20%"></view></view>
        <view class="sl"><view class="dot" style="left: 60%"></view></view>
        <view class="sl"><view class="dot" style="left: 35%"></view></view>
      </view>
    </view>

    <text class="tab-label">{{item.text}}</text>
  </view>
</view>
