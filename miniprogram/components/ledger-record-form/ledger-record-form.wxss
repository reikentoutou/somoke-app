/* ===== 记账表单组件（录入页 / 班次详情内联编辑共用） ===== */

.lrf {
  display: block;
}

/* ===== 顶部提示 Banner ===== */

.lrf-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid transparent;
}

.lrf-banner--warn {
  background: #FFF7E6;
  border-color: #FFE1A8;
}

.lrf-banner--info {
  background: #F0F7FF;
  border-color: #CBE1FF;
}

.lrf-banner-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.lrf-banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #AD6800;
  line-height: 1.4;
}

.lrf-banner-desc {
  font-size: 24rpx;
  color: #6B5425;
  line-height: 1.5;
}

.lrf-banner--info .lrf-banner-desc {
  color: #1F4680;
}

.lrf-banner-action {
  flex-shrink: 0;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #FA8C16;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 500;
}

/* ===== 上班数据预填提示 ===== */

.lrf-prefill-hint {
  font-size: 22rpx;
  color: #8A8A8A;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

/* ===== 日期 & 班次 ===== */

.picker-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 60rpx;
}

.picker-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 40rpx;
}

.picker-card .label-sm {
  margin-bottom: 24rpx;
}

.picker-value {
  font-size: 40rpx;
  font-weight: 500;
  color: #000000;
}

.picker-value--empty {
  font-weight: 400;
  color: #888888;
}

/* ===== 记账姓名 ===== */

.name-section {
  margin-bottom: 60rpx;
}

.name-section .label-sm {
  display: block;
  margin-bottom: 12rpx;
}

.name-picker-display {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #c6c6c6;
}

.name-display-text {
  font-size: 48rpx;
  font-weight: 600;
  color: #000000;
}

.name-picker-chev {
  font-size: 40rpx;
  color: #c6c6c6;
  padding-left: 16rpx;
}

/* ===== 数量 ===== */

.qty-card {
  margin-bottom: 60rpx;
  padding: 48rpx;
}

.qty-row {
  display: flex;
  align-items: stretch;
}

.qty-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.qty-col.right {
  text-align: right;
}

.qty-label {
  display: block;
  margin-bottom: 12rpx;
  text-align: center;
}

.qty-label.right {
  text-align: center;
}

.qty-input {
  width: 100%;
  height: 96rpx;
  min-height: 96rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 96rpx;
  color: #000000;
  text-align: center;
  background: transparent;
}

.qty-input.right {
  text-align: center;
}

.qty-divider {
  width: 2rpx;
  align-self: center;
  min-height: 96rpx;
  height: 96rpx;
  background: rgba(198, 198, 198, 0.3);
  margin: 0 24rpx;
  flex-shrink: 0;
}

.field-req {
  color: #ba1a1a;
  font-weight: 700;
  margin-left: 4rpx;
}

/* ===== 上下班现金 ===== */

.cash-card {
  margin-bottom: 60rpx;
  padding: 48rpx;
}

.cash-card-kicker {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #666666;
  text-transform: uppercase;
  margin-bottom: 28rpx;
}

.cash-row {
  align-items: flex-end;
}

.cash-divider {
  align-self: stretch;
  min-height: 120rpx;
  height: auto;
}

.cash-input {
  width: 100%;
  height: 96rpx;
  min-height: 96rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 96rpx;
  color: #000000;
  text-align: center;
  background: transparent;
}

.cash-input.right {
  text-align: center;
}

/* ===== 支付渠道 ===== */

.payment-section {
  margin-bottom: 60rpx;
}

.payment-section .title-md {
  display: block;
  margin-bottom: 32rpx;
}

.pay-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx;
  margin-bottom: 16rpx;
}

.pay-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.pay-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
}

.pay-icon.wechat  { background: #07C160; }
.pay-icon.alipay  { background: #1677FF; }
.pay-icon.cash    { background: #000000; }
.pay-icon.gift-icon { background: #ba1a1a; }

.pay-name {
  font-size: 30rpx;
  font-weight: 500;
}

.pay-name.err {
  color: #ba1a1a;
}

.pay-input {
  width: 160rpx;
  text-align: right;
  font-size: 36rpx;
  font-weight: 600;
  background: transparent;
}

.pay-input.err {
  color: #ba1a1a;
}

/* ===== Summary（黑底） ===== */

.summary-card {
  background: #000000;
  color: #e2e2e2;
  padding: 48rpx;
  border-radius: 48rpx;
  margin-bottom: 60rpx;
  box-shadow: 0 40rpx 80rpx rgba(0, 0, 0, 0.1);
}

.summary-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  opacity: 0.6;
  margin-bottom: 36rpx;
}

.summary-main {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding-bottom: 28rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.1);
  margin-bottom: 28rpx;
}

.summary-main-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-end;
  width: 100%;
}

.summary-formula {
  display: block;
  font-size: 22rpx;
  line-height: 1.45;
  opacity: 0.55;
  margin-top: 16rpx;
}

.summary-hint {
  font-size: 28rpx;
  opacity: 0.8;
}

.summary-big {
  font-size: 60rpx;
  font-weight: 700;
  letter-spacing: -2rpx;
}

.summary-revenue-block {
  margin-bottom: 28rpx;
  padding-bottom: 28rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.1);
}

.summary-hint-rev {
  display: block;
  margin-bottom: 12rpx;
}

.summary-revenue-jpy {
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.summary-inventory-hint {
  margin-bottom: 8rpx;
}

.summary-inventory-text {
  font-size: 22rpx;
  line-height: 1.45;
  opacity: 0.5;
}

.soft-warn-box {
  margin-top: 24rpx;
  margin-bottom: 8rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background-color: rgba(255, 183, 77, 0.14);
  border: 2rpx solid rgba(255, 183, 77, 0.35);
}

.soft-warn-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #ffb84d;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.soft-warn-line {
  display: block;
  font-size: 24rpx;
  line-height: 1.55;
  color: rgba(255, 224, 180, 0.95);
  margin-bottom: 12rpx;
}

.soft-warn-line:last-child {
  margin-bottom: 0;
}

/* ===== 提交按钮 ===== */

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  padding: 40rpx 0;
  background: #000000;
  color: #e2e2e2;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  transition: all 0.2s;
}

.submit-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.submit-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.arrow {
  font-size: 36rpx;
}
