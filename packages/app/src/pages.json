{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue"
    }
  },
  "pages": [
    { "path": "pages/overview/index", "style": { "navigationBarTitleText": "概览" } },
    { "path": "pages/login/index", "style": { "navigationBarTitleText": "登录" } },
    { "path": "pages/onboarding/index", "style": { "navigationBarTitleText": "完善资料" } },
    { "path": "pages/store-create/index", "style": { "navigationBarTitleText": "创建门店" } },
    { "path": "pages/store-join/index", "style": { "navigationBarTitleText": "加入门店" } },
    { "path": "pages/store-select/index", "style": { "navigationBarTitleText": "选择门店" } },
    { "path": "pages/entry/index", "style": { "navigationBarTitleText": "Ledger" } },
    { "path": "pages/reports/index", "style": { "navigationBarTitleText": "报表" } },
    { "path": "pages/settings/index", "style": { "navigationBarTitleText": "设置" } },
    { "path": "pages/profile-edit/index", "style": { "navigationBarTitleText": "编辑资料" } },
    { "path": "pages/settings-shifts/index", "style": { "navigationBarTitleText": "班次管理" } },
    {
      "path": "pages/settings-recorders/index",
      "style": { "navigationBarTitleText": "记账员管理" }
    },
    { "path": "pages/settings-team/index", "style": { "navigationBarTitleText": "成员管理" } },
