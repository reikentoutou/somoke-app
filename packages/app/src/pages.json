    { "path": "pages/stock-ledger/index", "style": { "navigationBarTitleText": "运营与流水" } },
    { "path": "pages/stock-adjust/index", "style": { "navigationBarTitleText": "库存调整" } }
  ],
  "tabBar": {
    "custom": true,
    "color": "#999999",
    "selectedColor": "#1a1c1d",
    "backgroundColor": "#ffffff",
    "list": [
      { "pagePath": "pages/overview/index", "text": "概览" },
      { "pagePath": "pages/entry/index", "text": "录入" },
      { "pagePath": "pages/reports/index", "text": "报表" },
      { "pagePath": "pages/settings/index", "text": "设置" }
    ]
  },
  "globalStyle": {
    "navigationBarBackgroundColor": "#f9f9fb",
    "navigationBarTitleText": "Ledger",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#f9f9fb",
    "backgroundTextStyle": "dark"
  }
}
